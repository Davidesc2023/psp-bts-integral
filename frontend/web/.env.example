# ============================================================
# PSP — Variables de entorno del frontend
# ============================================================
# Copia como .env.local para desarrollo local.
# NUNCA subir .env.local ni .env al repositorio.
# Valores en: Supabase Dashboard > Project Settings > API
# ============================================================

# URL del proyecto Supabase (sin barra final)
VITE_SUPABASE_URL=https://<PROJECT-REF>.supabase.co

# Clave pública anónima (segura para exponer en frontend)
VITE_SUPABASE_ANON_KEY=<ANON-KEY>

# Entorno actual (development | staging | production)
VITE_APP_ENV=development

# Nombre del producto
VITE_APP_NAME=PSP Pacientes
