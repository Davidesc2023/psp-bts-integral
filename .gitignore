# ============================================================
# PSP — Root .gitignore
# ============================================================

# Variables de entorno — NUNCA subir
.env
.env.local
.env.*.local
.env.production
.env.staging
*.local

# Node
node_modules/
.npm

# Build outputs
dist/
dist-ssr/
build/
.next/
out/

# Supabase local dev
supabase/.branches/
supabase/.temp/
supabase/local-db/

# OS
.DS_Store
Thumbs.db
desktop.ini

# Editores
.vscode/*
!.vscode/extensions.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*

# Temporales
*.tmp
*.temp
*.bak

# Cobertura de tests
coverage/
.nyc_output/
