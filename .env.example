# ============================================================
# PSP — Variables de Entorno
# ============================================================
# Copia este archivo a .env y completa con tus valores reales.
# NUNCA subas el archivo .env al repositorio (está en .gitignore)
# ============================================================

# ==== SUPABASE ====
# URL del proyecto Supabase (disponible en: Project Settings > API)
VITE_SUPABASE_URL=https://<tu-proyecto-id>.supabase.co

# Clave anónima de Supabase (public, restringida por RLS)
# (disponible en: Project Settings > API > anon public)
VITE_SUPABASE_ANON_KEY=<tu-anon-key>

# ============================================================
# NOTAS DE SEGURIDAD
# ============================================================
# - La ANON KEY solo tiene los permisos definidos por Row Level Security (RLS)
# - NUNCA uses la SERVICE_ROLE KEY en el frontend
# - Asegúrate de tener RLS habilitado en todas las tablas sensibles
# ============================================================
